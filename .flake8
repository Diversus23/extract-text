[flake8]
max-line-length = 88
extend-ignore = 
    # Совместимость с Black
    E203
    W503
    W504
    # Общие исключения
    E501
    F401
    # Ошибки сортировки импортов (для постепенного внедрения)
    I100
    I201

exclude = 
    .git
    __pycache__
    .pytest_cache
    .mypy_cache
    .coverage
    coverage_html
    .tox
    .venv
    venv
    build
    dist
    *.egg-info
    .eggs
    tests/test_*.txt
    tests/test_*.ok.txt
    tests/test_*.err.txt

per-file-ignores =
    # Тесты: имена методов уже описательные, docstring-required правила тут не нужны.
    # D100-D107 покрывают отсутствующие docstring у модуля/класса/метода/функции.
    # D200/D205/D400/D401 — стилистические правила для оформления docstring.
    tests/*:F401,F811,S101,D100,D101,D102,D103,D104,D107,D200,D205,D400,D401
    # __init__.py файлы могут содержать неиспользуемые импорты
    __init__.py:F401
    # Конфигурационные файлы
    app/config.py:E501
    # FastAPI требует Depends()/Security()/Header() в default-аргументах —
    # B008 здесь является ложным срабатыванием.
    app/auth.py:B008
    app/main.py:B008

max-complexity = 20
count = True
statistics = True
show-source = True 